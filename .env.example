# MikroTik MCP Server - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Router credentials (reference these in devices.json with ${VAR_NAME})
ROUTER_MAIN_USER=admin
ROUTER_MAIN_PASSWORD=your_secure_password_here

ROUTER_BRANCH_USER=admin
ROUTER_BRANCH_PASSWORD=your_secure_password_here

ROUTER_LEGACY_USER=admin
ROUTER_LEGACY_PASSWORD=your_secure_password_here

# SSH key passphrase (if using encrypted SSH keys)
SSH_KEY_PASSPHRASE=your_key_passphrase_here

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FILE=mikrotik_mcp.log
